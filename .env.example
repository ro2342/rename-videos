# Provedor de IA para geração de slugs
# Opções: anthropic | ollama | cmd
AI_PROVIDER=anthropic

# Anthropic (padrão)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # modelo usado (padrão acima)

# Ollama (local, sem API key)
# AI_PROVIDER=ollama
# OLLAMA_MODEL=llama3

# Qualquer CLI que leia prompt via stdin e escreva o slug em stdout
# AI_PROVIDER=cmd
# AI_CMD=gemini -p

# Whisper
# WHISPER_MODEL=large-v3-turbo  # padrão
